rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users: read/update own doc, admin reads/writes all
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Orders: users create/read own; admin reads/writes all
    match /orders/{orderId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Recharges: users create/read own; admin reads/writes all
    match /recharges/{rechargeId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Balance history: users read/create own; admin reads/writes all
    match /balance_history/{docId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Services: public read, admin write
    match /services/{serviceId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // Catalog: public read, admin write
    match /catalog/{docId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // Settings: authenticated users read (for payment data), admin write
    match /settings/{doc} {
      allow read:   if isAuth() || true;
      allow write:  if isAdmin();
    }

    // Support tickets: users read/create own; admin reads/writes all
    match /support_tickets/{ticketId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read:   if isAuth() && (get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isAuth() && (get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid || isAdmin());
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }
  }
}
